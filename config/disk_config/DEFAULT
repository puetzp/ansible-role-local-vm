# p=<partlabel> <mountpoint> <size>   <fs type> <mount options> <misc options>

# entire disk with LVM, separate /home

disk_config disk1 disklabel:gpt fstabkey:uuid align-at:1M

p=efi     /boot/efi 512M  vfat  rw
p=boot    /boot     500   ext4  rw,noatime
p=system  -         4G-   -     -

disk_config lvm

vg vg1  disk1.3
vg1-root     /           3G       ext4    noatime,rw
vg1-swap     swap        1G       swap    sw
vg1-home     /home       1G       ext4    noatime,nosuid,nodev,noexec,rw
vg1-var      /var        3G       ext4    noatime,nosuid,nodev,rw
vg1-var_log  /var/log    1G       ext4    noatime,nosuid,nodev,noexec,rw

disk_config tmpfs
tmpfs        /tmp      RAM:50%          noatime,nosuid,nodev,noexec,rw
